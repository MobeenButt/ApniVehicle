<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_vehicle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:backgroundTint="@color/surface_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_vehicle_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image_vehicle"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/VehicleCardImageShape"
            tools:src="@drawable/ic_launcher_background" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_verified"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:text="@string/verified"
            android:textColor="@color/white"
            app:chipBackgroundColor="@color/success"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_vehicle"
            tools:text="Toyota Corolla Altis 2021" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="12dp"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            tools:text="PKR 4,250,000" />

        <LinearLayout
            android:id="@+id/row_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_price">

            <ImageView
                android:id="@+id/icon_mileage"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_mileage"
                app:tint="@color/text_secondary"
                app:srcCompat="@drawable/ic_speed"
                tools:srcCompat="@drawable/ic_speed" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_mileage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="38,000 km" />

            <View
                android:id="@+id/divider_1"
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/icon_location"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_location"
                app:tint="@color/text_secondary"
                app:srcCompat="@drawable/ic_location"
                tools:srcCompat="@drawable/ic_location" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Lahore" />

            <View
                android:id="@+id/divider_2"
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/icon_fuel"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_fuel"
                app:tint="@color/text_secondary"
                app:srcCompat="@drawable/ic_local_gas_station"
                tools:srcCompat="@drawable/ic_local_gas_station" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_fuel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Petrol" />

        </LinearLayout>

        <ImageView
            android:id="@+id/icon_favorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/cd_favorite"
            app:tint="@color/primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:srcCompat="@drawable/ic_favorite" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_view_details"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="6dp"
            android:text="@string/view_details"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>


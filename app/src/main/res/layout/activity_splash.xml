<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Animated Background Gradient Overlay -->
    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3" />

    <!-- Particle Container 1 (Background Layer) -->
    <View
        android:id="@+id/particle1"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle2"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle3"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle4"
        android:layout_width="7dp"
        android:layout_height="7dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle5"
        android:layout_width="9dp"
        android:layout_height="9dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle6"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle7"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/particle8"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/particle_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Rotating Glow Ring -->
    <ImageView
        android:id="@+id/glowRing"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/glow_ring"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Pulsing Heart Container -->
    <FrameLayout
        android:id="@+id/heartContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.35">

        <!-- Heart Background Glow -->
        <ImageView
            android:id="@+id/heartGlow"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/heart_glow"
            android:layout_gravity="center"
            android:alpha="0" />

        <!-- Main Logo with Heart -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_car_rental"
            android:layout_gravity="center"
            android:alpha="0"
            app:tint="@android:color/white" />

    </FrameLayout>

    <!-- App Name with Animation -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@android:color/white"
        android:textSize="38sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:alpha="0"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/heartContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Tagline with Animation -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/splash_tagline"
        android:textColor="#BBDEFB"
        android:textSize="16sp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/tvAppName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Animated Progress Container -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="32dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Custom Progress Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@drawable/progress_background">

            <View
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_foreground" />

        </FrameLayout>

        <!-- Loading Text -->
        <TextView
            android:id="@+id/tvLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading your journey..."
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Bouncing Car Animation -->
    <ImageView
        android:id="@+id/bouncingCar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_directions_car"
        android:alpha="0"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toTopOf="@+id/tvVersion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <!-- Version Text -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Powered by ApniVehicle v2.0"
        android:textColor="#90CAF9"
        android:textSize="12sp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

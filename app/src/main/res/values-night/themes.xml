<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark Theme for ApniVehicle -->
    <style name="Base.Theme.ApniVehicle" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_cta</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.ApniVehicle.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ApniVehicle.MediumComponent</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.ApniVehicle" parent="Base.Theme.ApniVehicle" />
    
    <style name="Theme.ApniVehicle.NoActionBar" parent="Theme.ApniVehicle">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- Shape Appearances -->
    <style name="ShapeAppearance.ApniVehicle.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.ApniVehicle.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>

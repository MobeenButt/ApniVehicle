<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- TYPOGRAPHY STYLES -->

    <!-- Base TextStyle -->
    <style name="TextStyle" />

    <!-- Page Title: 22sp, Bold -->
    <style name="TextStyle.PageTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Section Header: 16sp, SemiBold -->
    <style name="TextStyle.SectionHeader">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Body Text: 14sp, Regular -->
    <style name="TextStyle.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Caption/Meta: 12sp, Regular -->
    <style name="TextStyle.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Button Label: 14sp, Medium, ALL CAPS -->
    <style name="TextStyle.ButtonLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/button_text_white</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- SHAPE STYLES -->

    <!-- Base ShapeAppearance -->
    <style name="ShapeAppearance" />

    <!-- Card corner radius: 12dp -->
    <style name="ShapeAppearance.Card">
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Button corner radius: 8dp -->
    <style name="ShapeAppearance.Button">
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Shape style for card images with rounded top corners -->
    <style name="VehicleCardImageShape">
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>

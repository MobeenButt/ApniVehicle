hs_err_pid*
replay_pid*

# End of https://www.toptal.com/developers/gitignore/api/kotlin

# Gradle build cache (should be ignored)
.gradle/

# IDE files
.idea/
*.iml

# Build output
build/

# Local properties
local.properties

# Gradle wrapper is tracked in git - don't ignore gradle/ directory
# Only ignore the build cache .gradle/ above
.gradle/
build/
local.properties
